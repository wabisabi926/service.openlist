<?xml version="1.0" encoding="UTF-8"?>
<addon id="service.openlist" name="OpenList Service" version="4.1.10" provider-name="wabisabi926">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="service.py" start="login">
        <provides>service</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>OpenList Service</summary>
        <description>启动和管理 openlist 服务器的服务插件，支持安卓和Linux平台，需要手动添加对应平台的二进制文件到bin/android或bin/linux子文件夹中，文件统一命名为openlist，默认账号密码为admin和admin</description>
        <platform>all</platform>
        <license>GPL-2.0-or-later</license>
        <news>支持安卓和Linux平台，根据不同架构自动选择对应二进制文件，需要手动添加二进制文件到bin/android或bin/linux子文件夹中，文件统一命名为openlist，默认账号密码改为admin和admin</news>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
